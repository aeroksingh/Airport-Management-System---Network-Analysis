# ── Stage: Production ─────────────────────────────────────
FROM node:18-alpine

WORKDIR /app

# Copy package files first (layer caching)
COPY package*.json ./

# Install production dependencies only
RUN npm ci --omit=dev

# Copy source code (.dockerignore excludes .env, node_modules, logs/)
COPY . .

# Create logs directory (volume will be mounted here)
RUN mkdir -p logs

# Expose backend port
EXPOSE 5000

# Start the server
CMD ["node", "server.js"]